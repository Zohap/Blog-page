<%- include("partials/header") %>

<div class="container">
<a href="/posts" class="back-link">
    ← Back to Posts
</a>
    <div class="card">

        <h1><%= post.title %></h1>

        <p>
            <strong><%= post.author %></strong>
            •
            <%= post.createdAt %>
        </p>

        <p>
            <%= post.content %>
        </p>

        <a href="/posts/<%= post.id %>/edit">
            Edit
        </a>

        <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" class="delete-form">
            <button class="delete">
                Delete
            </button>
        </form>

    </div>

</div>

<%- include("partials/footer") %>