<%- include("partials/header") %>

<div class="form-container">

    <a href="/posts" class="back-link">
        ← Back to Posts
    </a>

    <h1>Edit Blog Post</h1>

    <form
        action="/posts/<%= post.id %>?_method=PUT"
        method="POST"
    >

        <div class="form-group">
            <label>Title</label>

            <input
                type="text"
                name="title"
                value="<%= post.title %>"
                required
            >
        </div>

        <div class="form-group">
            <label>Author</label>

            <input
                type="text"
                name="author"
                value="<%= post.author %>"
                required
            >
        </div>

        <div class="form-group">
            <label>Content</label>

            <textarea
                name="content"
                required
            ><%= post.content %></textarea>
        </div>

        <button
            type="submit"
            class="submit-btn"
        >
            Update Post
        </button>

    </form>

</div>

<%- include("partials/footer") %>