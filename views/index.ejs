<%- include("partials/header") %>

<div class="container">
    <div class="posts-grid">

        <% posts.forEach(post => { %>

            <div class="card">

                <h2><%= post.title %></h2>

                <p>
                    <strong><%= post.author %></strong>
                </p>

                <p>
                    <%= post.content.substring(0, 100) %>...
                </p>

                <a href="/posts/<%= post.id %>">
                    Read More
                </a>

            </div>

        <% }) %>

    </div>

</div>

<%- include("partials/footer") %>